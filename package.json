{
  "name": "lexora",
  "version": "0.1.0",
  "private": true,
  "description": "Lexora multilingual language-learning documentation website.",
  "scripts": {
    "dev": "node scripts/generate-content.mjs && next dev",
    "generate-content": "node scripts/generate-content.mjs",
    "clean:next": "node scripts/clear-next-cache.mjs",
    "build": "node scripts/generate-content.mjs && next build",
    "build:github": "NEXT_PUBLIC_BASE_PATH=/lexora NEXT_PUBLIC_SITE_URL=https://actionanand.github.io node scripts/generate-content.mjs && NEXT_PUBLIC_BASE_PATH=/lexora NEXT_PUBLIC_SITE_URL=https://actionanand.github.io next build",
    "build:cloudflare": "NEXT_PUBLIC_BASE_PATH= NEXT_PUBLIC_SITE_URL=https://ar-lexora.pages.dev node scripts/generate-content.mjs && NEXT_PUBLIC_BASE_PATH= NEXT_PUBLIC_SITE_URL=https://ar-lexora.pages.dev next build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "mermaid": "^11.4.1",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.9.0 <25"
  }
}
